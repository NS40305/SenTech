---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../components/layout/FloatingRfqButton.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import PageHero from '../components/primitives/PageHero.astro';
import OemWorkflow from '../components/home/OemWorkflow.astro';
import RfqSection from '../components/home/RfqSection.astro';
import { t } from '../i18n/ui';

const locale = 'en' as const;
const home = await getEntry('home', 'home-en');
const oem = home?.data.oem;

const capabilities = [
  {
    title: 'Curve & B-value matching',
    body: 'Submit a target R/T curve, B-value, or competitor part number. Our engineering team selects the closest stocked element or designs a new chip recipe in-house.',
  },
  {
    title: 'Mechanical customization',
    body: 'Lead material (PVC / Teflon / silicone), lead diameter and length, sleeve, connector or harness termination. We deliver a manufacturable mechanical drawing for review.',
  },
  {
    title: 'Tolerance grading',
    body: '±0.10 °C interchangeable, ±1% point-matched, or ±5% high-volume. Mixed-tolerance lots possible for cost-optimized BOMs.',
  },
  {
    title: 'Qualification support',
    body: 'On-site or in-lab qualification including thermal-cycle, vibration, humidity, and aging tests. AEC-Q200 and IATF 16949 documentation packages on request.',
  },
  {
    title: 'In-house chip-to-sensor',
    body: 'NTC chip, element assembly, encapsulation, calibration, and finished-sensor packaging — all under one roof in Taiwan. Single supplier, single accountability point.',
  },
  {
    title: 'Volume scaling',
    body: 'Pilot quantities (≤100) for prototyping; qualification samples in 5 working days; mass production aligned to your forecast and packaging requirements.',
  },
];

const slas = [
  { value: '5', unit: 'days', label: 'Feasibility review' },
  { value: '10–20', unit: 'days', label: 'First qualification samples' },
  { value: '4–6', unit: 'weeks', label: 'Mass production ramp' },
];
---
<BaseLayout
  title="OEM Service & Customization — SEN TECH"
  description={t(locale, 'page.oem.sub')}
  locale={locale}
  path="/oem"
>
  <SiteHeader slot="header" locale={locale} />

  <PageHero
    eyebrow={t(locale, 'page.oem.eyebrow')}
    title={t(locale, 'page.oem.title')}
    subtitle={t(locale, 'page.oem.sub')}
  />

  {oem && (
    <OemWorkflow
      locale={locale}
      eyebrow={oem.eyebrow}
      title={oem.title}
      body={oem.body}
      steps={oem.steps}
      leadTimeNote={oem.leadTimeNote}
      ctaLabel={oem.ctaLabel}
    />
  )}

  <Section surface="mist">
    <Container>
      <header class="cap__header">
        <Eyebrow>Capabilities</Eyebrow>
        <h2 class="cap__title">What we customize for OEMs.</h2>
        <p class="cap__sub">Six areas where SEN TECH engineering meets your spec instead of forcing you to fit a stocked part.</p>
      </header>
      <ul class="cap__grid">
        {capabilities.map((c, i) => (
          <li class="cap__item">
            <span class="cap__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="cap__item-title">{c.title}</h3>
            <p class="cap__item-body">{c.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <Section surface="navy" paddingY="tight">
    <Container>
      <div class="sla">
        <div class="sla__intro">
          <Eyebrow class="sla__eyebrow">Lead times</Eyebrow>
          <h2 class="sla__title">Engineering reply, not an auto-responder.</h2>
        </div>
        <ul class="sla__grid">
          {slas.map((s) => (
            <li>
              <span class="sla__value">{s.value}</span>
              <span class="sla__unit">{s.unit}</span>
              <span class="sla__label">{s.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </Section>

  <RfqSection
    locale={locale}
    eyebrow="Start an OEM project"
    bullets={[
      'Send target spec / drawing / part number',
      'Reply from a SEN TECH engineer in one business day',
      'Samples in 5 working days',
    ]}
  />

  <SiteFooter slot="footer" locale={locale} />
  <FloatingRfqButton locale={locale} />
</BaseLayout>

<style>
  .cap__header {
    display: flex; flex-direction: column; gap: var(--space-3);
    max-width: 64ch; margin-bottom: var(--space-6);
  }
  .cap__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    color: var(--color-primary);
    line-height: 1.2;
  }
  .cap__sub {
    font-size: 16px; color: var(--color-text-body); line-height: 1.6;
  }
  .cap__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr; gap: var(--space-4);
  }
  .cap__item {
    background: #fff; border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card); padding: var(--space-4);
    display: flex; flex-direction: column; gap: var(--space-2);
    transition: border-color var(--duration-fast) var(--easing-base);
  }
  .cap__item:hover { border-color: var(--color-accent); }
  .cap__num {
    font-family: var(--font-mono); font-size: 22px; font-weight: 700;
    color: var(--color-accent); letter-spacing: -0.02em;
  }
  .cap__item-title {
    font-family: var(--font-display); font-size: 18px; font-weight: 700;
    color: var(--color-primary); line-height: 1.3;
  }
  .cap__item-body {
    font-size: 14px; color: var(--color-text-body); line-height: 1.55;
  }
  @media (min-width: 768px) {
    .cap__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .cap__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  }

  .sla { display: grid; grid-template-columns: 1fr; gap: var(--space-5); align-items: center; }
  .sla__intro :global(.sla__eyebrow) { color: var(--color-accent); }
  .sla__title {
    font-family: var(--font-display); color: #fff;
    font-size: clamp(22px, 2.6vw, 30px); line-height: 1.2; margin-top: var(--space-2);
  }
  .sla__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3);
  }
  .sla__grid li { display: flex; flex-direction: column; gap: 2px; }
  .sla__value {
    font-family: var(--font-mono); font-size: clamp(28px, 3.6vw, 38px);
    font-weight: 700; color: #fff; line-height: 1;
  }
  .sla__unit {
    font-size: 12px; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .sla__label {
    font-size: 13px; color: rgba(255,255,255,0.78); margin-top: var(--space-2);
  }
  @media (min-width: 1024px) {
    .sla { grid-template-columns: minmax(0, 5fr) minmax(0, 7fr); gap: var(--space-7); }
  }
</style>

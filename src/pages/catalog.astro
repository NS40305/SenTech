---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../components/layout/FloatingRfqButton.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import PageHero from '../components/primitives/PageHero.astro';
import { localizedPath, t } from '../i18n/ui';

const locale = 'en' as const;
const catalogPdf = '/pdfs/sentech-catalog-placeholder.pdf';

const products = await getCollection('products', ({ data }) => data.locale === 'en');
const sortedProducts = products
  .map((e) => e.data)
  .sort((a, b) => a.name.localeCompare(b.name));
---
<BaseLayout
  title="Product Catalog — Online Preview — SEN TECH"
  description="Read or download the full SEN TECH NTC thermistor catalog online."
  locale={locale}
  path="/catalog"
>
  <SiteHeader slot="header" locale={locale} />

  <PageHero
    eyebrow="Catalog"
    title="SEN TECH NTC thermistor catalog."
    subtitle="Read the full product catalog online or jump straight to any per-product datasheet below."
  />

  <Section surface="white">
    <Container>
      <div class="cat__layout">
        <aside class="cat__side">
          <div class="cat__actions">
            <a class="btn btn--primary cat__download" href={catalogPdf} download>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12 4v12" stroke-linecap="round" />
                <path d="M6 12l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M4 20h16" stroke-linecap="round" />
              </svg>
              <span>Download catalog</span>
            </a>
            <a class="cat__open-new" href={catalogPdf} target="_blank" rel="noopener">
              Open in new tab
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M6 3H3v10h10v-3M9 3h4v4M9 7l5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>

          <div class="cat__list">
            <h2>Per-product datasheets</h2>
            <ul>
              {sortedProducts.map((p) => (
                <li>
                  <a href={localizedPath(locale, `/products/${p.slug}`)}>
                    <span class="cat__list-name">{p.name}</span>
                    <span class="cat__list-meta">
                      <span class="cat__list-family">{p.family}</span>
                      <span class="cat__list-arrow" aria-hidden="true">→</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <div class="cat__viewer">
          <header class="cat__viewer-head">
            <Eyebrow>Online preview</Eyebrow>
            <h2 class="cat__viewer-title">Full product catalog</h2>
            <p class="cat__viewer-note">Placeholder catalog — replace <code>public/pdfs/sentech-catalog.pdf</code> with the production master catalog before launch.</p>
          </header>
          <div class="cat__frame-wrap">
            <object
              class="cat__frame"
              data={`${catalogPdf}#view=FitH&toolbar=1`}
              type="application/pdf"
              aria-label="SEN TECH product catalog PDF preview"
            >
              <div class="cat__inline-fallback">
                <div class="cat__mobile-icon" aria-hidden="true">
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M28 4H10a3 3 0 0 0-3 3v34a3 3 0 0 0 3 3h28a3 3 0 0 0 3-3V17z" />
                    <polyline points="28 4 28 17 41 17" />
                    <text x="14" y="34" font-family="monospace" font-size="9" fill="currentColor" stroke="none" font-weight="700">PDF</text>
                  </svg>
                </div>
                <h3 class="cat__mobile-title">SEN TECH product catalog</h3>
                <p class="cat__mobile-sub">Inline PDF preview isn't available on this browser. Open the file to view it.</p>
                <div class="cat__mobile-actions">
                  <a class="btn btn--primary" href={catalogPdf} target="_blank" rel="noopener">Open catalog</a>
                  <a class="btn btn--secondary" href={catalogPdf} download>Download</a>
                </div>
                <p class="cat__mobile-tip">Or pick a specific product datasheet from the list above.</p>
              </div>
            </object>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <SiteFooter slot="footer" locale={locale} />
  <FloatingRfqButton locale={locale} />
</BaseLayout>

<style>
  .cat__layout {
    display: grid; grid-template-columns: 1fr; gap: var(--space-5);
  }
  .cat__side { display: flex; flex-direction: column; gap: var(--space-4); }
  .cat__actions {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3);
  }
  .cat__download { display: inline-flex; align-items: center; gap: 8px; }
  .cat__open-new {
    color: var(--color-accent); font-weight: 600; font-size: 14px;
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
  }
  .cat__open-new:hover { text-decoration: underline; }

  .cat__list {
    background: var(--color-surface); border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card); padding: var(--space-4);
  }
  .cat__list h2 {
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-primary); margin-bottom: var(--space-3);
  }
  .cat__list ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .cat__list a {
    display: flex; justify-content: space-between; align-items: center; gap: var(--space-3);
    padding: 10px 12px; border-radius: var(--radius-button);
    text-decoration: none; color: var(--color-carbon);
    transition: background-color var(--duration-fast) var(--easing-base);
  }
  .cat__list a:hover { background: #fff; color: var(--color-accent); }
  .cat__list-name {
    font-family: var(--font-display); font-size: 14px; font-weight: 600;
  }
  .cat__list-meta { display: flex; gap: 10px; align-items: center; font-size: 11px; color: var(--color-text-muted); }
  .cat__list-family {
    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;
  }
  .cat__list-arrow { color: var(--color-accent); font-weight: 700; }

  .cat__viewer {
    background: #fff; border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card); overflow: hidden;
  }
  .cat__viewer-head {
    padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-stroke);
    background: var(--color-surface);
    display: flex; flex-direction: column; gap: 4px;
  }
  .cat__viewer-title {
    font-family: var(--font-display); font-size: 16px; font-weight: 700;
    color: var(--color-primary);
  }
  .cat__viewer-note {
    font-size: 12px; color: var(--color-text-muted);
  }
  .cat__viewer-note code {
    background: var(--color-surface-alt); padding: 1px 6px; border-radius: 3px;
    font-family: var(--font-mono); font-size: 11px;
  }
  .cat__frame-wrap {
    position: relative; height: clamp(420px, 80vh, 720px);
    background: var(--color-surface-alt);
  }
  .cat__frame {
    width: 100%; height: 100%; border: 0; display: block; background: #fff;
  }

  /* Inline fallback — only renders when <object> can't display the PDF */
  .cat__inline-fallback {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-4);
    text-align: center;
    background: linear-gradient(180deg, var(--color-surface) 0%, #fff 100%);
  }
  .cat__mobile-icon { width: 64px; height: 64px; color: var(--color-accent); margin-bottom: var(--space-2); }
  .cat__mobile-icon svg { width: 100%; height: 100%; }
  .cat__mobile-title {
    font-family: var(--font-display); font-size: 18px; font-weight: 700;
    color: var(--color-primary); line-height: 1.3;
  }
  .cat__mobile-sub { font-size: 14px; color: var(--color-text-body); line-height: 1.55; max-width: 38ch; }
  .cat__mobile-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center; margin-top: var(--space-2); }
  .cat__mobile-tip { font-size: 12px; color: var(--color-text-muted); margin-top: var(--space-3); }

  @media (min-width: 1024px) {
    .cat__layout { grid-template-columns: minmax(0, 4fr) minmax(0, 8fr); gap: var(--space-7); align-items: start; }
    .cat__frame-wrap { height: 820px; max-height: calc(100vh - 200px); }
  }
</style>

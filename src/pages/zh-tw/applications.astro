---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../../components/layout/FloatingRfqButton.astro';
import Section from '../../components/layout/Section.astro';
import Container from '../../components/layout/Container.astro';
import Eyebrow from '../../components/primitives/Eyebrow.astro';
import PageHero from '../../components/primitives/PageHero.astro';
import ProductCard from '../../components/home/ProductCard.astro';
import RfqSection from '../../components/home/RfqSection.astro';
import { t } from '../../i18n/ui';

const locale = 'zh-TW' as const;

const APPLICATION_ORDER = ['home-appliance', 'automotive-electronics', 'consumer-electronics-3c'];
const APPLICATION_IMAGES: Record<string, string> = {
  'home-appliance': '/images/app-home-appliance.jpg',
  'automotive-electronics': '/images/app-automotive.jpg',
  'consumer-electronics-3c': '/images/app-3c.jpg',
};
const USE_CASES: Record<string, string[]> = {
  'home-appliance': [
    '冰箱與冷凍庫溫度感測',
    '空調熱交換器與冷媒管溫度',
    '洗衣機水溫控制',
    '微波爐 / 烤箱腔體過溫保護',
    '熱水器與飲水機熱管理',
  ],
  'automotive-electronics': [
    '車艙與 HVAC 區域溫度',
    'EV 電池芯、模組與 BMS 感測',
    '車載充電器與轉換器熱保護',
    'ADAS 模組與 ECU 熱監控',
    'LED 大燈／尾燈熱回授',
  ],
  'consumer-electronics-3c': [
    '筆電 CPU 與電池溫度',
    '手機與平板電池熱保護',
    '穿戴裝置與智慧手錶皮膚接觸感測',
    '充電器過溫關斷',
    '相機與投影機熱管理',
  ],
};

const appEntries = await getCollection('applications', ({ data }) => data.locale === 'zh-TW');
const productEntries = await getCollection('products', ({ data }) => data.locale === 'zh-TW');
const productMap = new Map(productEntries.map((e) => [e.data.slug, e.data]));

const apps = APPLICATION_ORDER.map((slug) => {
  const entry = appEntries.find((e) => e.data.slug === slug);
  if (!entry) return null;
  const recommended = entry.data.recommendedProducts
    .map((rp) => productMap.get(rp))
    .filter((p): p is NonNullable<typeof p> => Boolean(p));
  return {
    slug,
    industry: entry.data.industry,
    body: entry.data.body,
    image: APPLICATION_IMAGES[slug] ?? '',
    useCases: USE_CASES[slug] ?? [],
    recommended,
  };
}).filter((a): a is NonNullable<typeof a> => Boolean(a));
---
<BaseLayout
  title="應用領域 — 家電、汽車電子、3C — 業達科技"
  description={t(locale, 'page.applications.sub')}
  locale={locale}
  path="/zh-tw/applications"
>
  <SiteHeader slot="header" locale={locale} />

  <PageHero
    eyebrow={t(locale, 'page.applications.eyebrow')}
    title={t(locale, 'page.applications.title')}
    subtitle={t(locale, 'page.applications.sub')}
  />

  <Section surface="white" paddingY="tight">
    <Container>
      <nav class="app-nav" aria-label="應用產業">
        {apps.map((a, i) => (
          <a class="app-nav__item" href={`#app-${a.slug}`}>
            <span class="app-nav__num">0{i + 1}</span>
            <span class="app-nav__label">{a.industry}</span>
          </a>
        ))}
      </nav>
    </Container>
  </Section>

  {apps.map((app, idx) => (
    <Section surface={idx % 2 === 0 ? 'mist' : 'white'} id={`app-${app.slug}`}>
      <Container>
        <div class="app-section">
          <div class="app-section__media">
            <img src={app.image} alt={app.industry} loading="lazy" decoding="async" width="800" height="600" />
            <span class="app-section__chip">0{idx + 1} / {apps.length}</span>
          </div>
          <div class="app-section__body">
            <Eyebrow>{t(locale, 'page.applications.eyebrow')}</Eyebrow>
            <h2 class="app-section__title">{app.industry}</h2>
            <p class="app-section__intro">{app.body}</p>

            {app.useCases.length > 0 && (
              <div class="app-section__cases">
                <h3>典型應用</h3>
                <ul>
                  {app.useCases.map((c) => (
                    <li>
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M3 8l3.5 3.5L13 5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>

        {app.recommended.length > 0 && (
          <div class="app-section__recommended">
            <header class="app-section__rec-header">
              <Eyebrow>{t(locale, 'page.applications.recommended')}</Eyebrow>
              <h3>{app.industry}適用產品</h3>
            </header>
            <div class="app-section__rec-grid">
              {app.recommended.map((p) => (
                <ProductCard
                  slug={p.slug}
                  family={p.family}
                  name={p.name}
                  tempMin={p.tempMin}
                  tempMax={p.tempMax}
                  tolerance={p.tolerance}
                  bValue={p.bValue}
                  dissipation={p.dissipation}
                  timeConstant={p.timeConstant}
                  maxPower={p.maxPower}
                  pdfUrl={p.pdfUrl}
                  image={p.image}
                  summary={p.summary}
                  locale={locale}
                />
              ))}
            </div>
          </div>
        )}
      </Container>
    </Section>
  ))}

  <RfqSection
    locale={locale}
    eyebrow="沒有看到您的產業？"
    bullets={[
      '提供應用情境簡述',
      '一個工作天內由工程師回覆',
      '歡迎客製化機構與電氣規格',
    ]}
  />

  <SiteFooter slot="footer" locale={locale} />
  <FloatingRfqButton locale={locale} />
</BaseLayout>

<style>
  .app-nav {
    display: grid; grid-template-columns: 1fr; gap: var(--space-2);
  }
  .app-nav__item {
    display: flex; align-items: center; gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card);
    text-decoration: none; color: var(--color-carbon);
    transition: border-color var(--duration-fast) var(--easing-base);
  }
  .app-nav__item:hover { border-color: var(--color-accent); }
  .app-nav__num {
    font-family: var(--font-mono); font-size: 13px;
    color: var(--color-accent); font-weight: 700;
  }
  .app-nav__label {
    font-family: var(--font-display); font-weight: 700;
    color: var(--color-primary); font-size: 15px;
  }

  .app-section {
    display: grid; grid-template-columns: 1fr; gap: var(--space-5);
    align-items: start;
  }
  .app-section__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-card);
    background: var(--color-surface-alt);
  }
  .app-section__media img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .app-section__chip {
    position: absolute; top: var(--space-3); left: var(--space-3);
    background: rgba(14, 42, 71, 0.92); color: #fff;
    padding: 4px 10px; border-radius: var(--radius-pill);
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    letter-spacing: 0.05em;
  }
  .app-section__body {
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .app-section__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 36px);
    color: var(--color-primary); line-height: 1.2;
  }
  .app-section__intro {
    font-size: 16px; color: var(--color-text-body); line-height: 1.6;
  }
  .app-section__cases {
    margin-top: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-stroke);
  }
  .app-section__cases h3 {
    font-family: var(--font-display); font-size: 14px; font-weight: 700;
    color: var(--color-primary); text-transform: uppercase;
    letter-spacing: 0.06em; margin-bottom: var(--space-3);
  }
  .app-section__cases ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--space-2);
  }
  .app-section__cases li {
    display: flex; gap: 10px; align-items: flex-start;
    font-size: 14px; color: var(--color-text-body); line-height: 1.5;
  }
  .app-section__cases svg {
    color: var(--color-accent); flex-shrink: 0; margin-top: 4px;
  }
  .app-section__recommended {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-stroke);
  }
  .app-section__rec-header {
    display: flex; flex-direction: column; gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .app-section__rec-header h3 {
    font-family: var(--font-display); font-size: 20px;
    color: var(--color-primary); font-weight: 700; line-height: 1.3;
  }
  .app-section__rec-grid {
    display: grid; grid-template-columns: 1fr; gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .app-section__rec-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .app-nav { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .app-section { grid-template-columns: minmax(0, 5fr) minmax(0, 7fr); gap: var(--space-7); }
    .app-section__rec-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

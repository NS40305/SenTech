---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/layout/SiteHeader.astro';
import SiteFooter from '../../../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../../../components/layout/FloatingRfqButton.astro';
import Section from '../../../components/layout/Section.astro';
import Container from '../../../components/layout/Container.astro';
import Eyebrow from '../../../components/primitives/Eyebrow.astro';
import Button from '../../../components/primitives/Button.astro';
import RfqSection from '../../../components/home/RfqSection.astro';
import VariantMatrix from '../../../components/products/VariantMatrix.astro';
import { localizedPath, t } from '../../../i18n/ui';

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => data.locale === 'zh-TW');
  return products.map((p) => ({
    params: { slug: p.data.slug },
    props: { product: p.data },
  }));
}

const { product } = Astro.props;
const locale = 'zh-TW' as const;
const imageSrc = `/images/product-${product.image}.jpg`;
const pdfUrl = product.pdfUrl ?? '/pdfs/sentech-catalog-placeholder.pdf';
const pdfFilename = pdfUrl.split('/').pop() ?? 'datasheet.pdf';

const variantData = await getEntry('variants', product.slug);

type Spec = { label: string; value: string; numeric?: boolean };
const specs: Spec[] = [
  { label: '產品系列', value: product.family },
  { label: '操作溫度範圍', value: `${product.tempMin} ~ ${product.tempMax} °C`, numeric: true },
  { label: '公差', value: product.tolerance },
];
if (product.bValue) specs.push({ label: 'B 值', value: product.bValue });
if (product.dissipation) specs.push({ label: '散逸常數', value: product.dissipation });
if (product.timeConstant) specs.push({ label: '熱時間常數', value: product.timeConstant });
if (product.maxPower) specs.push({ label: '最大功率', value: product.maxPower, numeric: true });
---
<BaseLayout
  title={`${product.name} — 規格與資料表 — 業達科技`}
  description={product.summary}
  locale={locale}
  path={`/zh-tw/products/${product.slug}`}
>
  <SiteHeader slot="header" locale={locale} />

  <Section surface="navy" paddingY="tight">
    <Container>
      <nav class="crumbs" aria-label="麵包屑">
        <a href={localizedPath(locale, '/')}>首頁</a>
        <span aria-hidden="true">/</span>
        <a href={localizedPath(locale, '/products')}>產品</a>
        <span aria-hidden="true">/</span>
        <span class="crumbs__current">{product.name}</span>
      </nav>
      <div class="page-head">
        <Eyebrow class="page-head__eyebrow">{product.family}</Eyebrow>
        <h1 class="page-head__title">{product.name}</h1>
        <p class="page-head__sub">{product.summary}</p>
      </div>
    </Container>
  </Section>

  <Section surface="white">
    <Container>
      <div class="detail">
        <aside class="detail__side">
          <figure class="detail__figure">
            <img src={imageSrc} alt={product.name} loading="lazy" decoding="async" width="600" height="450" />
            <figcaption>{product.family}</figcaption>
          </figure>

          <div class="detail__specs">
            <h2>產品規格</h2>
            <dl>
              {specs.map((s) => (
                <div class="detail__spec-row">
                  <dt>{s.label}</dt>
                  <dd class:list={[s.numeric && 'is-num']}>{s.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="detail__actions">
            <a class="btn btn--primary detail__download" href={pdfUrl} download={pdfFilename}>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12 4v12" stroke-linecap="round" />
                <path d="M6 12l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M4 20h16" stroke-linecap="round" />
              </svg>
              <span>下載 PDF</span>
            </a>
            <Button variant="secondary" href={localizedPath(locale, '/contact')}>
              {t(locale, 'cta.requestSample')}
            </Button>
          </div>

          <a class="detail__back" href={localizedPath(locale, '/products')}>
            <span aria-hidden="true">←</span>
            返回所有產品系列
          </a>
        </aside>

        <div class="detail__viewer">
          <header class="detail__viewer-head">
            <div class="detail__viewer-titlewrap">
              <Eyebrow>線上預覽</Eyebrow>
              <h2 class="detail__viewer-title">{product.name} — 完整資料表</h2>
            </div>
            <div class="detail__viewer-actions">
              <a class="detail__viewer-btn detail__viewer-btn--ghost" href={pdfUrl} target="_blank" rel="noopener">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="M6 3H3v10h10v-3M9 3h4v4M9 7l5-5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>新分頁開啟</span>
              </a>
              <a class="detail__viewer-btn detail__viewer-btn--solid" href={pdfUrl} download={pdfFilename}>
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="M8 2v9" stroke-linecap="round" />
                  <path d="M4 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3 14h10" stroke-linecap="round" />
                </svg>
                <span>下載</span>
              </a>
            </div>
          </header>
          <div class="detail__frame-wrap">
            <object
              class="detail__frame"
              data={`${pdfUrl}#view=FitH&toolbar=1`}
              type="application/pdf"
              title={`${product.name} 資料表 PDF`}
              aria-label={`${product.name} 資料表 PDF 預覽`}
            >
              <div class="detail__inline-fallback">
                <div class="detail__mobile-icon" aria-hidden="true">
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M28 4H10a3 3 0 0 0-3 3v34a3 3 0 0 0 3 3h28a3 3 0 0 0 3-3V17z" />
                    <polyline points="28 4 28 17 41 17" />
                    <text x="14" y="34" font-family="monospace" font-size="9" fill="currentColor" stroke="none" font-weight="700">PDF</text>
                  </svg>
                </div>
                <h3 class="detail__mobile-title">{product.name}</h3>
                <p class="detail__mobile-sub">您的瀏覽器無法內嵌預覽，請直接開啟檔案查看。</p>
                <div class="detail__mobile-actions">
                  <a class="btn btn--primary" href={pdfUrl} target="_blank" rel="noopener">開啟 PDF</a>
                  <a class="btn btn--secondary" href={pdfUrl} download={pdfFilename}>下載</a>
                </div>
              </div>
            </object>
          </div>
        </div>
      </div>

      {variantData && (
        <VariantMatrix
          locale={locale}
          productName={product.name}
          productSlug={product.slug}
          variants={variantData.data.matrix}
          bValues={variantData.data.bValues}
          r25Values={variantData.data.r25Values}
          accuracies={variantData.data.accuracies}
        />
      )}
    </Container>
  </Section>

  <RfqSection
    locale={locale}
    eyebrow="需要客製此料號？"
    bullets={[
      '提供目標規格或料號',
      '一個工作天內由工程師回覆',
      '5 個工作天內提供樣品',
    ]}
  />

  <SiteFooter slot="footer" locale={locale} />
  <FloatingRfqButton locale={locale} />
</BaseLayout>

<style>
  .crumbs {
    display: flex; gap: 8px; align-items: center;
    font-size: 13px; color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-4);
  }
  .crumbs a {
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none; font-weight: 500;
  }
  .crumbs a:hover { color: var(--color-accent); }
  .crumbs__current { color: #fff; font-weight: 600; }

  .page-head { display: flex; flex-direction: column; gap: var(--space-2); max-width: 880px; }
  .page-head :global(.page-head__eyebrow) { color: var(--color-accent); }
  .page-head__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.6vw, 42px);
    font-weight: 700; color: #fff; line-height: 1.15;
    letter-spacing: -0.015em;
  }
  .page-head__sub {
    font-size: clamp(15px, 1.6vw, 17px);
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.55; max-width: 64ch;
  }

  .detail {
    display: grid; grid-template-columns: 1fr; gap: var(--space-5);
  }
  .detail__side {
    display: flex; flex-direction: column; gap: var(--space-4);
  }
  .detail__figure {
    margin: 0; background: var(--color-surface-alt);
    border: 1px solid var(--color-stroke); border-radius: var(--radius-card);
    overflow: hidden; aspect-ratio: 4 / 3; position: relative;
  }
  .detail__figure img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .detail__figure figcaption {
    position: absolute; top: var(--space-3); left: var(--space-3);
    background: rgba(14, 42, 71, 0.92); color: #fff;
    padding: 4px 10px; border-radius: var(--radius-pill);
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  }
  .detail__specs {
    background: var(--color-surface); border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card); padding: var(--space-4);
  }
  .detail__specs h2 {
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-primary); margin-bottom: var(--space-3);
  }
  .detail__specs dl { margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .detail__spec-row {
    display: grid; grid-template-columns: 110px 1fr;
    column-gap: var(--space-3); align-items: baseline;
    padding-block: 6px;
    border-bottom: 1px solid var(--color-stroke);
  }
  .detail__spec-row:last-child { border-bottom: none; }
  .detail__spec-row dt {
    font-size: 10.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--color-text-muted);
  }
  .detail__spec-row dd {
    margin: 0; font-size: 13px; color: var(--color-carbon); font-weight: 500;
    overflow-wrap: anywhere;
  }
  .detail__spec-row dd.is-num {
    font-family: var(--font-mono); font-weight: 600; letter-spacing: -0.01em;
  }
  .detail__actions {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
  }
  .detail__download {
    display: inline-flex; align-items: center; gap: 8px;
  }
  .detail__back {
    color: var(--color-text-muted); text-decoration: none; font-size: 13px;
    font-weight: 500;
  }
  .detail__back:hover { color: var(--color-accent); }

  .detail__viewer {
    background: #fff; border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card); overflow: hidden;
    display: flex; flex-direction: column;
  }
  .detail__viewer-head {
    display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-stroke);
    background: var(--color-surface);
  }
  .detail__viewer-titlewrap { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .detail__viewer-title {
    font-family: var(--font-display); font-size: 16px; font-weight: 700;
    color: var(--color-primary); line-height: 1.3;
  }
  .detail__viewer-actions { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .detail__viewer-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-body); font-size: 13px; font-weight: 600;
    text-decoration: none; line-height: 1;
    padding: 8px 14px; border-radius: var(--radius-button);
    transition: background-color var(--duration-fast) var(--easing-base),
      border-color var(--duration-fast) var(--easing-base),
      color var(--duration-fast) var(--easing-base);
  }
  .detail__viewer-btn--ghost { color: var(--color-accent); background: transparent; border: 1.5px solid rgba(0, 166, 192, 0.3); }
  .detail__viewer-btn--ghost:hover { background: rgba(0, 166, 192, 0.08); border-color: var(--color-accent); }
  .detail__viewer-btn--solid { color: #fff; background: var(--color-accent); border: 1.5px solid var(--color-accent); }
  .detail__viewer-btn--solid:hover { background: var(--color-primary); border-color: var(--color-primary); }
  .detail__frame-wrap {
    position: relative; width: 100%;
    height: clamp(420px, 80vh, 720px);
    background: var(--color-surface-alt);
  }
  .detail__frame {
    width: 100%; height: 100%; border: 0; display: block; background: #fff;
  }

  .detail__inline-fallback {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-4);
    background: linear-gradient(180deg, var(--color-surface) 0%, #fff 100%);
    text-align: center;
  }
  .detail__mobile-icon {
    width: 64px; height: 64px;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }
  .detail__mobile-icon svg { width: 100%; height: 100%; }
  .detail__mobile-title {
    font-family: var(--font-display);
    font-size: 18px; font-weight: 700;
    color: var(--color-primary); line-height: 1.3;
  }
  .detail__mobile-sub {
    font-size: 14px; color: var(--color-text-body); line-height: 1.55;
    max-width: 38ch;
  }
  .detail__mobile-actions {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-2);
  }

  @media (min-width: 1024px) {
    .detail {
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      gap: var(--space-7);
      align-items: start;
    }
    .detail__frame-wrap { height: 820px; max-height: calc(100vh - 200px); }
  }
</style>

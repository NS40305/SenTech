---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/layout/SiteHeader.astro';
import SiteFooter from '../../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../../components/layout/FloatingRfqButton.astro';
import Hero from '../../components/home/Hero.astro';
import NumbersStrip from '../../components/home/NumbersStrip.astro';
import ReasonsToChoose from '../../components/home/ReasonsToChoose.astro';
import ProductGrid from '../../components/home/ProductGrid.astro';
import OemWorkflow from '../../components/home/OemWorkflow.astro';
import ApplicationsSection from '../../components/home/ApplicationsSection.astro';
import ManufacturingDiagram from '../../components/home/ManufacturingDiagram.astro';
import MilestoneTimeline from '../../components/home/MilestoneTimeline.astro';
import CertificationStrip from '../../components/home/CertificationStrip.astro';
import RfqSection from '../../components/home/RfqSection.astro';
import { t } from '../../i18n/ui';

const locale = 'zh-TW' as const;
const home = await getEntry('home', 'home-zh-tw');
const milestones = await getEntry('milestones', 'milestones-zh-tw');
const certs = await getEntry('certifications', 'certifications');

const productEntries = await getCollection('products', ({ data }) => data.locale === 'zh-TW');
const products = productEntries.map((e) => e.data);

const applicationOrder = ['home-appliance', 'automotive-electronics', 'consumer-electronics-3c'];
const applicationImageMap: Record<string, string> = {
  'home-appliance': '/images/app-home-appliance.jpg',
  'automotive-electronics': '/images/app-automotive.jpg',
  'consumer-electronics-3c': '/images/app-3c.jpg',
};
const appEntries = await getCollection('applications', ({ data }) => data.locale === 'zh-TW');
const applications = applicationOrder
  .map((slug) => appEntries.find((e) => e.data.slug === slug))
  .filter((e): e is NonNullable<typeof e> => Boolean(e))
  .map((e) => ({
    slug: e.data.slug,
    industry: e.data.industry,
    body: e.data.body,
    image: applicationImageMap[e.data.slug] ?? '/images/app-home-appliance.jpg',
    cta: '查看應用案例',
  }));

if (!home || !milestones || !certs) {
  throw new Error('Missing required content entries for zh-TW homepage');
}

const homeData = home.data;
const heroImagePath = '/images/hero-1.jpg';

const rfqBullets = [
  '5 個工作天可行性評估',
  '樣品直接由內部試產線交付',
  '工程師親自回覆，非自動化銷售訊息',
];
---
<BaseLayout
  title="業達科技 SEN TECH — 精密 NTC 感測元件，從晶片到感測器全製程自主生產"
  description={homeData.hero.subhead}
  locale={locale}
  path="/zh-tw"
  headerOverlay={true}
>
  <SiteHeader slot="header" locale={locale} transparent={true} />

  <Hero
    locale={locale}
    headline={homeData.hero.headline}
    subhead={homeData.hero.subhead}
    ctaPrimaryLabel={homeData.hero.ctaPrimaryLabel}
    ctaSecondaryLabel={homeData.hero.ctaSecondaryLabel}
    heroImage={heroImagePath}
    stats={homeData.hero.stats}
  />

  <NumbersStrip numbers={homeData.numbers} />

  <ReasonsToChoose
    eyebrow="為什麼選擇業達"
    title="OEM 客戶選擇業達的三個理由。"
    reasons={homeData.reasons}
  />

  <ProductGrid
    locale={locale}
    eyebrow={homeData.productsIntro.eyebrow}
    title={homeData.productsIntro.title}
    subtitle={homeData.productsIntro.subtitle}
    viewAllLabel={t(locale, 'cta.viewAllProducts')}
    products={products}
  />

  <OemWorkflow
    locale={locale}
    eyebrow={homeData.oem.eyebrow}
    title={homeData.oem.title}
    body={homeData.oem.body}
    steps={homeData.oem.steps}
    leadTimeNote={homeData.oem.leadTimeNote}
    ctaLabel={homeData.oem.ctaLabel}
  />

  <ApplicationsSection
    locale={locale}
    eyebrow={homeData.applicationsIntro.eyebrow}
    title={homeData.applicationsIntro.title}
    subtitle={homeData.applicationsIntro.subtitle}
    applications={applications}
  />

  <ManufacturingDiagram
    eyebrow={homeData.manufacturing.eyebrow}
    title={homeData.manufacturing.title}
    body={homeData.manufacturing.body}
    tiles={homeData.manufacturing.tiles}
  />

  <MilestoneTimeline
    eyebrow={homeData.about.eyebrow}
    title={homeData.about.title}
    body={homeData.about.body}
    items={milestones.data.items}
  />

  <CertificationStrip
    eyebrow="認證"
    title="我們的產品依循的品質系統與合規框架。"
    items={certs.data.items}
  />

  <RfqSection locale={locale} eyebrow="聯絡我們" bullets={rfqBullets} />

  <SiteFooter slot="footer" locale={locale} />
  <FloatingRfqButton locale={locale} />
</BaseLayout>

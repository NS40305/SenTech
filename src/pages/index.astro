---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import FloatingRfqButton from '../components/layout/FloatingRfqButton.astro';
import Section from '../components/layout/Section.astro';
import Container from '../components/layout/Container.astro';
---
<BaseLayout
  title="SEN TECH — Precision NTC sensors"
  description="From NTC chip to finished sensor under one roof."
  locale="en"
  path="/"
>
  <SiteHeader slot="header" locale="en" />
  <Section surface="white">
    <Container>
      <h1>SEN TECH</h1>
      <p>From NTC chip to finished sensor — under one roof.</p>
    </Container>
  </Section>
  <SiteFooter slot="footer" locale="en" />
  <FloatingRfqButton locale="en" />
</BaseLayout>

---
export interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class:list={['eyebrow', className]}>
  <slot />
</span>

<style>
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
</style>

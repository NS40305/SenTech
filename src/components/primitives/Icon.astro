---
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

export interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;
const here = dirname(fileURLToPath(import.meta.url));
const iconPath = resolve(here, '../../assets/icons', `${name}.svg`);
const svgContent = existsSync(iconPath)
  ? readFileSync(iconPath, 'utf-8').replace(
      /<svg([^>]*)>/,
      `<svg$1 width="${size}" height="${size}" class="${className ?? ''}">`
    )
  : `<!-- icon not found: ${name} -->`;
---
<Fragment set:html={svgContent} />

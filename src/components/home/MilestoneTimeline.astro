---
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Eyebrow from '../primitives/Eyebrow.astro';

export interface Props {
  eyebrow: string;
  title: string;
  body: string;
  items: Array<{ year: number; title: string; body: string }>;
}

const { eyebrow, title, body, items } = Astro.props;
const sortedItems = [...items].sort((a, b) => a.year - b.year);
---
<Section surface="white" id="about">
  <Container>
    <header class="timeline__header">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h2 class="timeline__title">{title}</h2>
      <p class="timeline__body">{body}</p>
    </header>
    <ol class="timeline">
      {sortedItems.map((item, i) => (
        <li class="timeline__item" data-position={i % 2 === 0 ? 'left' : 'right'}>
          <div class="timeline__marker" aria-hidden="true">
            <span class="timeline__dot"></span>
          </div>
          <div class="timeline__content">
            <div class="timeline__year">{item.year}</div>
            <h3 class="timeline__milestone">{item.title}</h3>
            <p class="timeline__text">{item.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </Container>
</Section>

<style>
  .timeline__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 64ch;
    margin-bottom: var(--space-6);
  }
  .timeline__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.2;
    color: var(--color-primary);
  }
  .timeline__body {
    font-size: 16px;
    color: var(--color-text-body);
    line-height: 1.6;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 12px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-stroke);
  }
  .timeline__item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
    position: relative;
  }
  .timeline__item:last-child { padding-bottom: 0; }
  .timeline__marker {
    position: relative;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }
  .timeline__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-surface);
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 1;
  }
  .timeline__content {
    background: var(--color-surface);
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    transition: border-color var(--duration-fast) var(--easing-base);
  }
  .timeline__item:hover .timeline__content { border-color: var(--color-accent); }
  .timeline__year {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }
  .timeline__milestone {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .timeline__text {
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.55;
  }
  @media (min-width: 768px) {
    .timeline::before {
      left: 50%;
      transform: translateX(-50%);
    }
    .timeline__item {
      grid-template-columns: 1fr 32px 1fr;
    }
    .timeline__item[data-position='left'] .timeline__content {
      grid-column: 1;
      text-align: right;
    }
    .timeline__item[data-position='left'] .timeline__marker {
      grid-column: 2;
    }
    .timeline__item[data-position='right'] .timeline__marker {
      grid-column: 2;
    }
    .timeline__item[data-position='right'] .timeline__content {
      grid-column: 3;
    }
    .timeline__item[data-position='left'] .timeline__content {
      grid-row: 1;
    }
  }
</style>

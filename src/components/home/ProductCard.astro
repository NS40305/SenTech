---
export interface Props {
  slug: string;
  family: string;
  name: string;
  tempMin: number;
  tempMax: number;
  tolerance: string;
  bValue?: string;
  image: string;
  summary: string;
  href?: string;
  ctaLabel?: string;
}

const {
  slug,
  family,
  name,
  tempMin,
  tempMax,
  tolerance,
  bValue,
  image,
  summary,
  href,
  ctaLabel = 'View details',
} = Astro.props;

const imageSrc = `/images/product-${image}.jpg`;
---
<article class="product-card" data-slug={slug}>
  <div class="product-card__media">
    <img src={imageSrc} alt={name} loading="lazy" decoding="async" width="480" height="320" />
    <span class="product-card__family">{family}</span>
  </div>
  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <p class="product-card__summary">{summary}</p>
    <dl class="product-card__specs">
      <div>
        <dt>Temp.</dt>
        <dd><span class="num">{tempMin}</span> ~ <span class="num">{tempMax}</span> °C</dd>
      </div>
      <div>
        <dt>Tol.</dt>
        <dd>{tolerance}</dd>
      </div>
      {bValue && (
        <div>
          <dt>B-value</dt>
          <dd>{bValue}</dd>
        </div>
      )}
    </dl>
    {href && (
      <a class="product-card__cta" href={href}>
        {ctaLabel}
        <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--easing-base),
      transform var(--duration-fast) var(--easing-base),
      box-shadow var(--duration-fast) var(--easing-base);
  }
  .product-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(14, 42, 71, 0.08);
  }
  .product-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-surface-alt);
    overflow: hidden;
  }
  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-card__family {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    background: rgba(14, 42, 71, 0.92);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }
  .product-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .product-card__name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
  }
  .product-card__summary {
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.55;
    flex: 1;
  }
  .product-card__specs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
    gap: var(--space-2) var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-stroke);
    margin: 0;
  }
  .product-card__specs div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .product-card__specs dt {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }
  .product-card__specs dd {
    font-size: 13px;
    color: var(--color-carbon);
    margin: 0;
    font-weight: 500;
  }
  .product-card__specs .num {
    font-family: var(--font-mono);
  }
  .product-card__cta {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-2);
  }
  .product-card__cta:hover {
    text-decoration: underline;
  }
</style>

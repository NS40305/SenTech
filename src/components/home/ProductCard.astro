---
import PdfPreview from '../primitives/PdfPreview.astro';
import type { Locale } from '../../i18n/ui';

export interface Props {
  slug: string;
  family: string;
  name: string;
  tempMin: number;
  tempMax: number;
  tolerance: string;
  bValue?: string;
  dissipation?: string;
  timeConstant?: string;
  maxPower?: string;
  pdfUrl?: string;
  image: string;
  summary: string;
  href?: string;
  ctaLabel?: string;
  pdfLabel?: string;
  locale?: Locale;
}

const {
  slug,
  family,
  name,
  tempMin,
  tempMax,
  tolerance,
  bValue,
  dissipation,
  timeConstant,
  maxPower,
  pdfUrl,
  image,
  summary,
  href,
  ctaLabel = 'View details',
  pdfLabel,
  locale = 'en',
} = Astro.props;

const pdfTriggerLabel =
  pdfLabel ?? (locale === 'zh-TW' ? 'PDF 型錄規格下載' : 'PDF Specification');
const effectivePdfUrl = pdfUrl ?? '/pdfs/sentech-catalog-placeholder.pdf';

type SpecRow = { label: string; value: string; numeric?: boolean; emphasis?: boolean };

const primarySpecs: SpecRow[] = [
  {
    label: 'Operating',
    value: `${tempMin} ~ ${tempMax} °C`,
    numeric: true,
    emphasis: true,
  },
  { label: 'Tolerance', value: tolerance, emphasis: true },
];
if (bValue) primarySpecs.push({ label: 'B-value', value: bValue });

const secondarySpecs: SpecRow[] = [];
if (dissipation) secondarySpecs.push({ label: 'Dissipation', value: dissipation });
if (timeConstant) secondarySpecs.push({ label: 'Time const.', value: timeConstant });
if (maxPower) secondarySpecs.push({ label: 'Max power', value: maxPower, numeric: true });

const imageSrc = `/images/product-${image}.jpg`;
---
<article class="product-card" data-slug={slug}>
  <div class="product-card__media">
    <img src={imageSrc} alt={name} loading="lazy" decoding="async" width="480" height="320" />
    <span class="product-card__family">{family}</span>
  </div>
  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <p class="product-card__summary">{summary}</p>

    <dl class="spec-table">
      {primarySpecs.map((s) => (
        <div class:list={['spec-row', s.emphasis && 'spec-row--emphasis']}>
          <dt class="spec-row__label">{s.label}</dt>
          <dd class:list={['spec-row__value', s.numeric && 'spec-row__value--num']}>{s.value}</dd>
        </div>
      ))}

      {secondarySpecs.length > 0 && (
        <>
          <div class="spec-divider" aria-hidden="true"></div>
          {secondarySpecs.map((s) => (
            <div class="spec-row spec-row--secondary">
              <dt class="spec-row__label">{s.label}</dt>
              <dd class:list={['spec-row__value', s.numeric && 'spec-row__value--num']}>{s.value}</dd>
            </div>
          ))}
        </>
      )}
    </dl>

    <div class="product-card__actions">
      <PdfPreview
        pdfUrl={effectivePdfUrl}
        triggerLabel={pdfTriggerLabel}
        modalTitle={`${name} — ${pdfTriggerLabel}`}
        locale={locale}
        variant="inline"
      />
      {href && (
        <a class="product-card__cta" href={href}>
          {ctaLabel}
          <span aria-hidden="true">→</span>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color var(--duration-fast) var(--easing-base),
      transform var(--duration-fast) var(--easing-base),
      box-shadow var(--duration-fast) var(--easing-base);
  }
  .product-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(14, 42, 71, 0.08);
  }
  .product-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-surface-alt);
    overflow: hidden;
  }
  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .product-card__family {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    background: rgba(14, 42, 71, 0.92);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: var(--radius-pill);
  }
  .product-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .product-card__name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
  }
  .product-card__summary {
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.55;
    flex: 1;
  }

  /* unified spec table */
  .spec-table {
    margin: 0;
    padding: var(--space-3) 0 0 0;
    border-top: 1px solid var(--color-stroke);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .spec-row {
    display: grid;
    grid-template-columns: 86px 1fr;
    column-gap: var(--space-3);
    align-items: baseline;
    line-height: 1.45;
  }
  .spec-row__label {
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
    white-space: nowrap;
  }
  .spec-row__value {
    margin: 0;
    font-size: 13px;
    color: var(--color-carbon);
    font-weight: 500;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .spec-row__value--num {
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .spec-row--emphasis .spec-row__value {
    color: var(--color-primary);
    font-size: 14px;
    font-weight: 700;
  }
  .spec-row--secondary .spec-row__label {
    font-size: 10px;
    color: var(--color-text-muted);
    opacity: 0.85;
  }
  .spec-row--secondary .spec-row__value {
    font-size: 12px;
    color: var(--color-text-body);
    font-weight: 500;
  }
  .spec-divider {
    height: 1px;
    background: var(--color-stroke);
    margin: 4px 0 2px 0;
    opacity: 0.7;
  }

  .product-card__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }
  .product-card__cta {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 13px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .product-card__cta:hover { text-decoration: underline; }

  @media (max-width: 380px) {
    .spec-row { grid-template-columns: 76px 1fr; column-gap: var(--space-2); }
  }
</style>

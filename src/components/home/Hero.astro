---
import Container from '../layout/Container.astro';
import Button from '../primitives/Button.astro';
import PdfPreview from '../primitives/PdfPreview.astro';
import { localizedPath, type Locale } from '../../i18n/ui';

export interface Props {
  locale: Locale;
  headline: string;
  subhead: string;
  ctaPrimaryLabel: string;
  ctaSecondaryLabel: string;
  heroImage?: string;
  catalogPdfUrl?: string;
  stats?: Array<{ value: string; suffix?: string; label: string }>;
}

const {
  locale,
  headline,
  subhead,
  ctaPrimaryLabel,
  ctaSecondaryLabel,
  heroImage = '/images/hero-1.jpg',
  catalogPdfUrl = '/pdfs/sentech-catalog-placeholder.pdf',
  stats = [],
} = Astro.props;

const catalogModalTitle =
  locale === 'zh-TW' ? 'SEN TECH 產品型錄' : 'SEN TECH Product Catalog';
---
<section class="hero">
  <div class="hero__media" aria-hidden="true">
    <img
      class="hero__media-img"
      src={heroImage}
      alt=""
      loading="eager"
      decoding="async"
      fetchpriority="high"
      width="768"
      height="600"
    />
    <div class="hero__media-scrim"></div>
  </div>
  <Container class="hero__content">
    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__subhead">{subhead}</p>
    <div class="hero__ctas">
      <Button variant="primary" href={localizedPath(locale, '/contact')}>{ctaPrimaryLabel}</Button>
      <PdfPreview
        pdfUrl={catalogPdfUrl}
        triggerLabel={ctaSecondaryLabel}
        modalTitle={catalogModalTitle}
        locale={locale}
        class="hero__pdf-trigger"
      />
    </div>
    {stats.length > 0 && (
      <ul class="hero__stats">
        {stats.map((s) => (
          <li>
            <span class="hero__stat-value">{s.value}{s.suffix ?? ''}</span>
            <span class="hero__stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    )}
  </Container>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-primary);
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    min-height: clamp(440px, 70vh, 760px);
    display: flex;
    align-items: center;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__media-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
  }
  .hero__media-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(14, 42, 71, 0.85) 0%,
        rgba(14, 42, 71, 0.55) 35%,
        rgba(14, 42, 71, 0.18) 65%,
        rgba(14, 42, 71, 0) 100%);
    pointer-events: none;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-7);
    max-width: 880px;
  }
  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: var(--space-4);
  }
  .hero__subhead {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.6vw, 19px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.86);
    max-width: 64ch;
    margin-bottom: var(--space-5);
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .hero__ctas :global(.btn--secondary) {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }
  .hero__ctas :global(.btn--secondary:hover) {
    background: #fff;
    color: var(--color-primary);
    border-color: #fff;
  }
  .hero__ctas :global(.hero__pdf-trigger) {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
    height: 48px;
    padding: 0 24px;
  }
  .hero__ctas :global(.hero__pdf-trigger:hover) {
    background: #fff;
    color: var(--color-primary);
    border-color: #fff;
  }
  .hero__stats {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }
  .hero__stats li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero__stat-value {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }
  .hero__stat-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.7);
  }
  @media (min-width: 768px) {
    .hero__content { padding-block: var(--space-8); }
  }
  @media (min-width: 1280px) {
    .hero__media-img { object-position: right bottom; }
    .hero__media-scrim {
      background:
        linear-gradient(95deg,
          rgba(14, 42, 71, 0.95) 0%,
          rgba(14, 42, 71, 0.78) 35%,
          rgba(14, 42, 71, 0.32) 65%,
          rgba(14, 42, 71, 0.05) 100%),
        linear-gradient(180deg,
          rgba(14, 42, 71, 0.55) 0%,
          rgba(14, 42, 71, 0.1) 60%,
          rgba(14, 42, 71, 0) 100%);
    }
  }
</style>

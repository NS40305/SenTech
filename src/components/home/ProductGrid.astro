---
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Eyebrow from '../primitives/Eyebrow.astro';
import Button from '../primitives/Button.astro';
import ProductCard from './ProductCard.astro';
import { localizedPath, type Locale } from '../../i18n/ui';

export interface Props {
  locale: Locale;
  eyebrow: string;
  title: string;
  subtitle: string;
  viewAllLabel: string;
  products: Array<{
    slug: string;
    family: string;
    name: string;
    tempMin: number;
    tempMax: number;
    tolerance: string;
    bValue?: string;
    image: string;
    summary: string;
  }>;
}

const { locale, eyebrow, title, subtitle, viewAllLabel, products } = Astro.props;
---
<Section surface="mist" id="products">
  <Container>
    <header class="product-grid__header">
      <div class="product-grid__intro">
        <Eyebrow>{eyebrow}</Eyebrow>
        <h2 class="product-grid__title">{title}</h2>
        <p class="product-grid__subtitle">{subtitle}</p>
      </div>
      <div class="product-grid__cta">
        <Button variant="secondary" href={localizedPath(locale, '/products')}>{viewAllLabel}</Button>
      </div>
    </header>
    <div class="product-grid">
      {products.map((p) => (
        <ProductCard
          slug={p.slug}
          family={p.family}
          name={p.name}
          tempMin={p.tempMin}
          tempMax={p.tempMax}
          tolerance={p.tolerance}
          bValue={p.bValue}
          image={p.image}
          summary={p.summary}
        />
      ))}
    </div>
  </Container>
</Section>

<style>
  .product-grid__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .product-grid__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 64ch;
  }
  .product-grid__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.2;
    color: var(--color-primary);
  }
  .product-grid__subtitle {
    font-size: 16px;
    color: var(--color-text-body);
    line-height: 1.6;
  }
  .product-grid__cta {
    display: flex;
    align-items: flex-start;
  }
  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 640px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
    .product-grid__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
    .product-grid__cta { justify-content: flex-end; }
  }
</style>

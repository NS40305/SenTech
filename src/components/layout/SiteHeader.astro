---
import Container from './Container.astro';
import LangSwitcher from './LangSwitcher.astro';
import Button from '../primitives/Button.astro';
import { localizedPath, t, type Locale } from '../../i18n/ui';

export interface Props {
  locale: Locale;
  transparent?: boolean;
}
const { locale, transparent = false } = Astro.props;
const path = Astro.url.pathname;
const navItems = [
  { key: 'nav.products' as const, href: localizedPath(locale, '/products') },
  { key: 'nav.oem' as const, href: localizedPath(locale, '/oem') },
  { key: 'nav.applications' as const, href: localizedPath(locale, '/applications') },
  { key: 'nav.manufacturing' as const, href: localizedPath(locale, '/manufacturing') },
  { key: 'nav.about' as const, href: localizedPath(locale, '/about') },
];
---
<header
  class:list={['site-header', transparent && 'site-header--transparent']}
  data-transparent={transparent ? 'true' : 'false'}
>
  <Container>
    <div class="row">
      <a class="brand" href={localizedPath(locale, '/')} aria-label="SEN TECH home">
        <img
          class="brand__logo"
          src="/images/logo.png"
          alt="SEN TECH"
          width="266"
          height="118"
        />
      </a>
      <nav class="nav" aria-label="Primary">
        <ul>
          {navItems.map(({ key, href }) => (
            <li><a href={href}>{t(locale, key)}</a></li>
          ))}
        </ul>
      </nav>
      <div class="actions">
        <LangSwitcher currentLocale={locale} currentPath={path} />
        <Button variant="primary" href={localizedPath(locale, '/contact')} class="header__cta">
          {t(locale, 'cta.sendInquiry')}
        </Button>
      </div>
    </div>
  </Container>
</header>

<script>
  function setupHeader() {
    const header = document.querySelector<HTMLElement>('.site-header');
    if (!header) return;
    const threshold = 40;
    const update = () => {
      const scrolled = window.scrollY > threshold;
      header.classList.toggle('is-scrolled', scrolled);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  if (document.readyState !== 'loading') setupHeader();
  else document.addEventListener('DOMContentLoaded', setupHeader);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(246, 248, 250, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-stroke);
    transition:
      background-color var(--duration-base) var(--easing-base),
      border-color var(--duration-base) var(--easing-base),
      backdrop-filter var(--duration-base) var(--easing-base),
      box-shadow var(--duration-base) var(--easing-base);
  }
  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 4px 20px rgba(14, 42, 71, 0.08);
    border-bottom-color: rgba(228, 231, 235, 0.6);
  }

  /* Transparent variant — used over the home Hero. */
  .site-header--transparent {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .site-header--transparent.is-scrolled {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    border-bottom-color: rgba(228, 231, 235, 0.6);
    box-shadow: 0 4px 20px rgba(14, 42, 71, 0.08);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    position: relative;
  }
  .brand__logo {
    display: block;
    height: 28px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    transition: filter var(--duration-base) var(--easing-base);
  }

  /* When transparent over hero (not scrolled): invert dark PNG logo to white */
  .site-header--transparent:not(.is-scrolled) .brand__logo {
    filter: brightness(0) invert(1);
  }

  @media (min-width: 768px) {
    .brand__logo { height: 32px; max-width: 160px; }
  }

  .nav ul {
    display: none;
    list-style: none;
    gap: var(--space-5);
  }
  .nav a {
    color: var(--color-carbon);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: color var(--duration-base) var(--easing-base);
    padding: 6px 0;
    position: relative;
  }
  .nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--duration-fast) var(--easing-base);
  }
  .nav a:hover { color: var(--color-accent); }
  .nav a:hover::after { transform: scaleX(1); }

  /* Transparent over hero — light text */
  .site-header--transparent:not(.is-scrolled) .nav a {
    color: rgba(255, 255, 255, 0.92);
  }
  .site-header--transparent:not(.is-scrolled) .nav a:hover {
    color: var(--color-accent);
  }

  .actions { display: flex; align-items: center; gap: var(--space-3); }

  /* Header CTA: solid in default; outlined-on-dark when transparent over hero */
  .site-header--transparent:not(.is-scrolled) :global(.header__cta) {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  .site-header--transparent:not(.is-scrolled) :global(.header__cta:hover) {
    background: #fff;
    color: var(--color-primary);
    border-color: #fff;
  }

  @media (min-width: 1024px) { .nav ul { display: flex; } }
</style>

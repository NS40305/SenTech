---
import FormField from './FormField.astro';
import FormSuccess from './FormSuccess.astro';
import Button from '../primitives/Button.astro';
import { t, type Locale } from '../../i18n/ui';

export interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const FORM_ENDPOINT = 'https://api.web3forms.com/submit';

const productOptions =
  locale === 'zh-TW'
    ? [
        '可互換式 NTC（IN）',
        '玻璃珠型（GB）',
        '單點匹配型（PM）',
        'HT 高精度',
        'HAT 高精度 AT',
        'TS 體溫感測',
        'TA-4 柔性引線',
        'TJ 薄膜',
        '其他 / 客製化需求',
      ]
    : [
        'Interchangeable NTC (IN)',
        'Glass Bead (GB)',
        'Point Matched (PM)',
        'HT High-Precision',
        'HAT High-Precision AT',
        'TS Body Temperature',
        'TA-4 Flexible Lead',
        'TJ Thin-Film',
        'Other / Custom request',
      ];

const subject =
  locale === 'zh-TW'
    ? '【SEN TECH 官網詢價】'
    : '[SEN TECH Website RFQ]';
---
<div class="rfq-form-wrap">
  <form
    class="rfq-form"
    action={FORM_ENDPOINT}
    method="POST"
    novalidate
    data-rfq-form
    data-locale={locale}
  >
    <input type="hidden" name="access_key" value={ACCESS_KEY} />
    <input type="hidden" name="subject" value={subject} />
    <input type="hidden" name="from_name" value="SEN TECH Website" />
    <input type="hidden" name="locale" value={locale} />
    <input type="checkbox" name="botcheck" class="rfq-form__honeypot" tabindex="-1" autocomplete="off" />

    <div class="rfq-form__grid">
      <FormField
        name="name"
        label={t(locale, 'rfq.field.name')}
        required
        autocomplete="name"
      />
      <FormField
        name="company"
        label={t(locale, 'rfq.field.company')}
        required
        autocomplete="organization"
      />
      <FormField
        name="email"
        label={t(locale, 'rfq.field.email')}
        type="email"
        required
        autocomplete="email"
        inputmode="email"
      />
      <FormField
        name="country"
        label={t(locale, 'rfq.field.country')}
        autocomplete="country-name"
      />
      <FormField
        name="product"
        label={t(locale, 'rfq.field.product')}
        type="select"
        required
        options={productOptions}
        placeholder={locale === 'zh-TW' ? '請選擇產品' : 'Select a product line'}
      />
      <FormField
        name="quantity"
        label={t(locale, 'rfq.field.quantity')}
        type="text"
        placeholder={locale === 'zh-TW' ? '例：50,000 / 年' : 'e.g. 50,000 / yr'}
      />
    </div>

    <div class="rfq-form__shortlist" data-rfq-shortlist hidden>
      <div class="rfq-form__shortlist-head">
        <strong data-rfq-shortlist-title>
          {locale === 'zh-TW' ? '已選規格' : 'Selected specifications'}
        </strong>
        <button type="button" class="rfq-form__shortlist-clear" data-rfq-shortlist-clear>
          {locale === 'zh-TW' ? '清空' : 'Clear all'}
        </button>
      </div>
      <ul class="rfq-form__shortlist-items" data-rfq-shortlist-items></ul>
      <p class="rfq-form__shortlist-hint">
        {locale === 'zh-TW'
          ? '上方規格將於送出時自動寫入訊息欄，並隨郵件送達工程團隊。'
          : 'These specs are auto-prepended to your message and sent with the inquiry.'}
      </p>
    </div>

    <FormField
      name="message"
      label={t(locale, 'rfq.field.message')}
      type="textarea"
      required
      rows={6}
      placeholder={
        locale === 'zh-TW'
          ? '請描述目標規格、應用情境、或附上料號 / 機構圖。'
          : 'Describe the target spec, application, or attach part numbers / drawings.'
      }
      hint={
        locale === 'zh-TW'
          ? '請避免在訊息中放置敏感資料；附件請另以郵件寄至 sales@sen-tech.com。'
          : 'Avoid sensitive data here; attachments via sales@sen-tech.com if needed.'
      }
    />

    <div class="rfq-form__error" role="alert" aria-live="assertive" data-rfq-error hidden></div>

    <div class="rfq-form__footer">
      <Button type="submit" variant="primary" class="rfq-form__submit">
        <span data-rfq-submit-label>{t(locale, 'cta.sendInquiry')}</span>
        <span data-rfq-submit-spinner hidden aria-hidden="true">…</span>
      </Button>
      <p class="rfq-form__sla">
        {locale === 'zh-TW'
          ? '一個工作天內由業達工程師回覆。'
          : 'A SEN TECH engineer replies within one business day.'}
      </p>
    </div>
  </form>

  <div data-rfq-success hidden>
    <FormSuccess
      title={t(locale, 'rfq.success.title')}
      body={t(locale, 'rfq.success.body')}
      resetLabel={t(locale, 'rfq.success.again')}
    />
  </div>
</div>

<script>
  const SHORTLIST_KEY = 'sentech.rfq.shortlist';

  type ShortlistItem = {
    slug: string;
    productName: string;
    bValue: number;
    r25: number;
    accuracy: string;
  };

  function readShortlist(): ShortlistItem[] {
    try {
      const raw = localStorage.getItem(SHORTLIST_KEY);
      const parsed = raw ? JSON.parse(raw) : [];
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function clearShortlist(): void {
    localStorage.removeItem(SHORTLIST_KEY);
    document.dispatchEvent(new CustomEvent('sentech:rfq:changed', { detail: { count: 0 } }));
  }

  function formatShortlist(items: ShortlistItem[], locale: string): string {
    if (!items.length) return '';
    const heading =
      locale === 'zh-TW'
        ? '【已選規格清單】'
        : '[Requested specifications]';
    const lines = items
      .map(
        (it) =>
          `  - ${it.productName}: B=${it.bValue} K, R25=${it.r25} kΩ, ${
            locale === 'zh-TW' ? '精度' : 'Accuracy'
          }=${it.accuracy}`
      )
      .join('\n');
    return `${heading}\n${lines}\n\n`;
  }

  function setupForm(form: HTMLFormElement) {
    const wrapper = form.closest('.rfq-form-wrap') as HTMLElement | null;
    if (!wrapper) return;
    const successPanel = wrapper.querySelector('[data-rfq-success]') as HTMLElement | null;
    const errorBox = form.querySelector('[data-rfq-error]') as HTMLElement | null;
    const submitLabel = form.querySelector('[data-rfq-submit-label]') as HTMLElement | null;
    const submitSpinner = form.querySelector('[data-rfq-submit-spinner]') as HTMLElement | null;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const messageField = form.querySelector('textarea[name="message"]') as HTMLTextAreaElement | null;
    const shortlistPanel = wrapper.querySelector('[data-rfq-shortlist]') as HTMLElement | null;
    const shortlistList = wrapper.querySelector('[data-rfq-shortlist-items]') as HTMLElement | null;
    const shortlistClearBtn = wrapper.querySelector('[data-rfq-shortlist-clear]') as HTMLButtonElement | null;
    const locale = form.dataset.locale ?? 'en';
    const errMsg =
      locale === 'zh-TW'
        ? '送出失敗，請稍後再試或直接寄信至 sales@sen-tech.com。'
        : 'Could not send — please retry or email sales@sen-tech.com.';
    const accessKey = (form.elements.namedItem('access_key') as HTMLInputElement | null)?.value ?? '';

    function renderShortlist(): void {
      const items = readShortlist();
      if (!shortlistPanel || !shortlistList) return;
      if (!items.length) {
        shortlistPanel.hidden = true;
        return;
      }
      shortlistPanel.hidden = false;
      shortlistList.innerHTML = '';
      items.forEach((it, idx) => {
        const li = document.createElement('li');
        li.className = 'rfq-form__shortlist-item';
        li.innerHTML = `
          <span class="rfq-form__shortlist-line">
            <span class="rfq-form__shortlist-name">${it.productName}</span>
            <span class="rfq-form__shortlist-spec">B=${it.bValue} K · R25=${it.r25} kΩ · ${it.accuracy}</span>
          </span>
          <button type="button" class="rfq-form__shortlist-remove" data-idx="${idx}" aria-label="${locale === 'zh-TW' ? '移除' : 'Remove'}">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>
          </button>`;
        shortlistList.appendChild(li);
      });
      shortlistList.querySelectorAll<HTMLButtonElement>('[data-idx]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const idx = Number(btn.dataset.idx);
          const items = readShortlist();
          items.splice(idx, 1);
          localStorage.setItem(SHORTLIST_KEY, JSON.stringify(items));
          document.dispatchEvent(new CustomEvent('sentech:rfq:changed', { detail: { count: items.length } }));
          renderShortlist();
        });
      });
    }

    shortlistClearBtn?.addEventListener('click', () => {
      clearShortlist();
      renderShortlist();
    });

    document.addEventListener('sentech:rfq:changed', renderShortlist);
    renderShortlist();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (errorBox) {
        errorBox.hidden = true;
        errorBox.textContent = '';
      }

      if (!accessKey) {
        if (errorBox) {
          errorBox.textContent =
            locale === 'zh-TW'
              ? '尚未設定 Web3Forms access_key（PUBLIC_WEB3FORMS_KEY 環境變數）。'
              : 'Web3Forms access_key is not configured (PUBLIC_WEB3FORMS_KEY env var).';
          errorBox.hidden = false;
        }
        return;
      }

      // Pre-pend selected variants to the message (visible to user before submit too)
      const shortlist = readShortlist();
      if (shortlist.length && messageField) {
        const prefix = formatShortlist(shortlist, locale);
        const userText = messageField.value.startsWith(prefix)
          ? messageField.value
          : prefix + messageField.value;
        messageField.value = userText;
      }

      if (!form.reportValidity()) return;

      submitBtn?.setAttribute('disabled', 'true');
      submitLabel?.setAttribute('hidden', '');
      submitSpinner?.removeAttribute('hidden');

      const data = new FormData(form);
      const payload: Record<string, FormDataEntryValue> = {};
      data.forEach((value, key) => {
        payload[key] = value;
      });
      if (shortlist.length) {
        payload.shortlist = JSON.stringify(shortlist);
      }

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(payload),
        });
        const json = (await res.json()) as { success?: boolean; message?: string };
        if (json.success) {
          form.hidden = true;
          if (successPanel) successPanel.hidden = false;
          form.reset();
          clearShortlist();
          renderShortlist();
        } else {
          if (errorBox) {
            errorBox.textContent = json.message ?? errMsg;
            errorBox.hidden = false;
          }
        }
      } catch {
        if (errorBox) {
          errorBox.textContent = errMsg;
          errorBox.hidden = false;
        }
      } finally {
        submitBtn?.removeAttribute('disabled');
        submitLabel?.removeAttribute('hidden');
        submitSpinner?.setAttribute('hidden', '');
      }
    });

    wrapper.querySelector('[data-action="reset"]')?.addEventListener('click', () => {
      if (successPanel) successPanel.hidden = true;
      form.hidden = false;
    });
  }

  document.querySelectorAll<HTMLFormElement>('[data-rfq-form]').forEach(setupForm);
</script>

<style>
  .rfq-form-wrap {
    background: #fff;
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-card);
    padding: var(--space-5);
  }
  .rfq-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .rfq-form__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3) var(--space-4);
  }
  .rfq-form__honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .rfq-form__error {
    background: rgba(180, 35, 24, 0.08);
    border: 1px solid rgba(180, 35, 24, 0.3);
    color: var(--color-error);
    border-radius: var(--radius-button);
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.5;
  }
  .rfq-form__shortlist {
    background: linear-gradient(180deg, rgba(0, 166, 192, 0.06) 0%, rgba(0, 166, 192, 0.02) 100%);
    border: 1px solid rgba(0, 166, 192, 0.25);
    border-radius: var(--radius-card);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .rfq-form__shortlist-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }
  .rfq-form__shortlist-head strong {
    font-family: var(--font-display);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }
  .rfq-form__shortlist-clear {
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: var(--radius-button);
  }
  .rfq-form__shortlist-clear:hover { color: var(--color-error); background: rgba(180, 35, 24, 0.05); }
  .rfq-form__shortlist-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .rfq-form__shortlist-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    padding: 8px 12px;
    background: #fff;
    border: 1px solid var(--color-stroke);
    border-radius: var(--radius-button);
    font-size: 13px;
  }
  .rfq-form__shortlist-line {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }
  .rfq-form__shortlist-name {
    font-weight: 600;
    color: var(--color-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rfq-form__shortlist-spec {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-body);
  }
  .rfq-form__shortlist-remove {
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color var(--duration-fast) var(--easing-base), color var(--duration-fast) var(--easing-base);
  }
  .rfq-form__shortlist-remove:hover {
    background: rgba(180, 35, 24, 0.1);
    color: var(--color-error);
  }
  .rfq-form__shortlist-hint {
    font-size: 11.5px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: 2px;
  }
  .rfq-form__footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    border-top: 1px solid var(--color-stroke);
    padding-top: var(--space-4);
  }
  .rfq-form__sla {
    font-size: 13px;
    color: var(--color-text-muted);
  }
  @media (min-width: 640px) {
    .rfq-form__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .rfq-form-wrap { padding: var(--space-6); }
  }
</style>

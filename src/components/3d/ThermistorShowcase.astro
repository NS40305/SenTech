---
import ThermistorShowcaseReact from './ThermistorShowcase.tsx';
import type { Locale } from '../../i18n/ui';

export interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const copy =
  locale === 'zh-TW'
    ? {
        eyebrow: '感測器運作中',
        title: '從晶片到感測器的精密路徑。',
        sub: 'NTC 晶片、元件、成品全程在同一條 R/T 曲線上 — 滑動頁面，看訊號實時流動。',
      }
    : {
        eyebrow: 'Sense the signal',
        title: 'Precision at the chip level.',
        sub: 'NTC chip → element → finished sensor, visualised end-to-end. Scroll to energise.',
      };
---
<div class="thermistor-island">
  <ThermistorShowcaseReact
    client:visible
    eyebrow={copy.eyebrow}
    title={copy.title}
    subtitle={copy.sub}
  />
</div>

<style is:global>
  .thermistor-island { display: block; }

  .thermistor-showcase {
    position: relative;
    background:
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(0, 166, 192, 0.18) 0%, rgba(0, 166, 192, 0) 60%),
      linear-gradient(180deg, #061325 0%, #0E2A47 100%);
    color: #fff;
    padding-block: var(--space-7);
    overflow: hidden;
    isolation: isolate;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .thermistor-showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 28px 28px;
    background-position: 0 0;
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .thermistor-showcase__intro {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto var(--space-5);
    padding-inline: var(--space-4);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .thermistor-showcase__eyebrow {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }
  .thermistor-showcase__title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.2vw, 36px);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
  }
  .thermistor-showcase__sub {
    font-size: clamp(14px, 1.6vw, 16px);
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0 auto;
  }

  .thermistor-showcase__canvas {
    position: relative;
    z-index: 1;
    width: 100%;
    height: clamp(320px, 50vh, 520px);
    margin-inline: auto;
    max-width: 1280px;
  }
  .thermistor-showcase__canvas canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    outline: none;
  }

  @media (min-width: 768px) {
    .thermistor-showcase {
      padding-block: var(--space-8);
    }
  }
</style>
